{
  "python_version": "3.13",
  "dockerfile_lines": [],
  "dependencies": [
    "./"
  ],
  "auth": {
    "path": "./graph_src_v2/auth/provider.py:oauth_auth"
  },
  "graphs": {
    "assistant": "./graph_src_v2/agents/assistant_agent/graph.py:graph",
    "deepagent_demo": "./graph_src_v2/agents/deepagent_agent/graph.py:graph"
  },
  "http": {
    "app": "./graph_src_v2/custom_routes/app.py:app",
    "cors": {
      "allow_origins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost",
        "http://127.0.0.1"
      ],
      "allow_methods": ["*"],
      "allow_headers": ["*"],
      "allow_credentials": false
    }
  },
  "env": "./graph_src_v2/.env"
}
