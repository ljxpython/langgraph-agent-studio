{
  "python_version": "3.13",
  "dockerfile_lines": [],
  "dependencies": [
    "./"
  ],
  "auth": {
    "path": "./graph_src_v2/auth/provider.py:oauth_auth"
  },
  "graphs": {
    "assistant": {
      "path": "./graph_src_v2/agents/assistant_agent/graph.py:graph",
      "description": "默认助手主入口：create_agent + 运行时动态工具装配，适合作为 OAuth 鉴权模式下的通用入口。"
    },
    "deepagent_demo": {
      "path": "./graph_src_v2/agents/deepagent_agent/graph.py:graph",
      "description": "deepagent 通用演示：包含 subagents + skills 的深度任务分解执行（鉴权模式）。"
    }
  },
  "http": {
    "app": "./graph_src_v2/custom_routes/app.py:app",
    "cors": {
      "allow_origins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost",
        "http://127.0.0.1"
      ],
      "allow_methods": ["*"],
      "allow_headers": ["*"],
      "allow_credentials": false
    }
  },
  "env": "./graph_src_v2/.env"
}
